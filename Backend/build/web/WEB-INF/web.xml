<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>WebCauDa_BookingSystem</display-name>

    <!-- 🟩 MẢNH GHÉP 1: BỘ LỌC ÉP PHÔNG CHỮ TIẾNG VIỆT TOÀN CỤC (CHARACTER ENCODING FILTER) -->
    <!-- Giải quyết triệt để lỗi vỡ font, dính ký tự dấu hỏi chấm (?) khi Admin thêm tên sân có dấu -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <param-name>ignore</param-name>
            <param-value>false</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 🟩 MẢNH GHÉP 2: ĐĂNG KÝ BỘ LỌC BẢO MẬT PHÂN QUYỀN TRUNG TÂM (ADMIN SECURITY FILTER) -->
    <!-- Chặn đứng 100% hành vi gõ mò URL truy cập trái phép vào vùng quản trị của khách hàng -->
    <filter>
        <filter-name>AdminSecurityFilter</filter-name>
        <filter-class>controller.AdminSecurityFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminSecurityFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- CẤU HÌNH TRANG CHÀO MỪNG MẶC ĐỊNH CHO ỨNG DỤNG ĐỘNG -->
    <!-- Định hướng Tomcat gọi trực tiếp HomeController lấy danh sách sân đấu thời gian thực từ DB -->
    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>

    <!-- CẤU HÌNH THỜI GIAN SỐNG CỦA SESSION VẬN HÀNH (30 PHÚT) -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- CẤU HÌNH TRANG BÁO LỖI TẬP TRUNG (CUSTOM ERROR PAGES) -->
    <!-- Thay thế màn hình sập xám xịt của Tomcat bằng trang cảnh báo chuyên nghiệp -->
    <error-page>
        <error-code>404</error-code>
        <location>/login.jsp?error=PageNotFound</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/login.jsp?error=SystemServerError</location>
    </error-page>
</web-app>